<div class="new-event-page mx-auto max-w-5xl">
  <div class="new-event-grid grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
    <section class="new-event-hero relative overflow-hidden rounded-[2rem] border border-white/50 bg-slate-950 px-6 py-8 text-white shadow-[0_30px_90px_-35px_rgba(15,23,42,0.7)] sm:px-8">
      <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-cyan-400 via-fuchsia-500 to-amber-300"></div>
      <div class="absolute inset-4 rounded-[1.5rem] border border-white/10"></div>
      <div class="absolute -left-10 top-10 h-36 w-36 rounded-full bg-cyan-400/25 blur-3xl"></div>
      <div class="absolute -right-10 bottom-0 h-40 w-40 rounded-full bg-fuchsia-500/25 blur-3xl"></div>

      <div class="relative">
        <div class="dashboard-sticker inline-flex rotate-[-3deg] rounded-full border border-white/30 bg-cyan-300 px-4 py-1 text-[10px] font-black uppercase tracking-[0.4em] text-slate-950 shadow-[4px_4px_0_0_rgba(255,255,255,0.2)]">
          Create the next move
        </div>
        <h1 class="new-event-hero__title mt-5 font-['Arial_Black','Trebuchet_MS',sans-serif] text-5xl font-black uppercase tracking-[-0.04em] sm:text-6xl">締切を追加</h1>
        <p class="new-event-hero__lead mt-4 max-w-md text-sm leading-6 text-slate-300">
          インターンでもイベントでも個人タスクでも、思いついた瞬間に入れておくと後でかなり楽になります。
        </p>

        <div class="new-event-features mt-8 grid gap-3 sm:grid-cols-2">
          <div class="new-event-feature rounded-3xl border border-white/15 bg-white/10 p-4 backdrop-blur">
            <div class="text-xs font-bold uppercase tracking-[0.3em] text-slate-300">Fast</div>
            <div class="mt-2 text-lg font-black">必要項目だけ</div>
          </div>
          <div class="new-event-feature rounded-3xl border border-white/15 bg-white/10 p-4 backdrop-blur">
            <div class="text-xs font-bold uppercase tracking-[0.3em] text-slate-300">Visible</div>
            <div class="mt-2 text-lg font-black">追加後すぐ一覧へ</div>
          </div>
        </div>
      </div>
    </section>

    <section class="new-event-form rounded-[2rem] border border-white/50 bg-white/75 p-6 shadow-[0_30px_90px_-35px_rgba(15,23,42,0.55)] backdrop-blur-xl sm:p-8">
      <%= form_with model: @event, url: events_path do |f| %>
        <div class="space-y-5">
          <div>
            <%= f.label :title, "タイトル", class: "mb-2 block text-sm font-black uppercase tracking-[0.2em] text-slate-500" %>
            <%= f.text_field :title, class: "new-event-input w-full rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-300 focus:border-fuchsia-400 focus:ring-4 focus:ring-fuchsia-200", placeholder: "Google STEP 応募" %>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <%= f.label :category, "カテゴリ", class: "mb-2 block text-sm font-black uppercase tracking-[0.2em] text-slate-500" %>
              <%= f.select :category, Event.categories.keys.map { |k| [k, k] }, {}, class: "new-event-input w-full rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-slate-900 outline-none transition focus:border-cyan-400 focus:ring-4 focus:ring-cyan-200" %>
            </div>

            <div>
              <%= f.label :organizer, "主催者", class: "mb-2 block text-sm font-black uppercase tracking-[0.2em] text-slate-500" %>
              <%= f.text_field :organizer, class: "new-event-input w-full rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-300 focus:border-cyan-400 focus:ring-4 focus:ring-cyan-200", placeholder: "Google" %>
            </div>
          </div>

          <div>
            <%= f.label :source_url, "URL", class: "mb-2 block text-sm font-black uppercase tracking-[0.2em] text-slate-500" %>
            <%= f.url_field :source_url, class: "new-event-input w-full rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-300 focus:border-amber-400 focus:ring-4 focus:ring-amber-200", placeholder: "https://example.com" %>
          </div>

          <%= fields_for :deadline, @deadline do |df| %>
            <div>
              <%= df.label :deadline_at, "締切日", class: "mb-2 block text-sm font-black uppercase tracking-[0.2em] text-slate-500" %>
              <%= df.date_field :deadline_at, class: "new-event-input w-full rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-slate-900 outline-none transition focus:border-rose-400 focus:ring-4 focus:ring-rose-200" %>
            </div>
          <% end %>

          <div class="pt-2">
            <%= f.submit "登録する", class: "dashboard-button dashboard-button--primary w-full cursor-pointer rounded-full border border-slate-900 bg-slate-950 px-5 py-3 text-sm font-black uppercase tracking-[0.2em] text-white transition hover:-translate-y-0.5 hover:bg-slate-800" %>
          </div>
        </div>
      <% end %>

      <%= link_to "一覧に戻る", deadlines_path, class: "new-event-back mt-5 inline-flex text-sm font-semibold text-slate-500 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-700" %>
    </section>
  </div>
</div>
