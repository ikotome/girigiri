<% urgency_config = {
  today: {
    label: "TODAY",
    accent: "from-rose-500 via-orange-400 to-amber-300",
    panel: "bg-rose-50/75 border-rose-200/70",
    badge: "bg-rose-500 text-white",
    pill: "bg-white/70 text-rose-700",
    ring: "shadow-[0_20px_60px_-25px_rgba(244,63,94,0.75)]"
  },
  soon: {
    label: "SOON",
    accent: "from-orange-500 via-amber-300 to-yellow-200",
    panel: "bg-orange-50/75 border-orange-200/70",
    badge: "bg-orange-500 text-white",
    pill: "bg-white/70 text-orange-700",
    ring: "shadow-[0_20px_60px_-25px_rgba(249,115,22,0.75)]"
  },
  week: {
    label: "THIS WEEK",
    accent: "from-cyan-500 via-sky-400 to-indigo-300",
    panel: "bg-sky-50/75 border-sky-200/70",
    badge: "bg-sky-500 text-white",
    pill: "bg-white/70 text-sky-700",
    ring: "shadow-[0_20px_60px_-25px_rgba(14,165,233,0.7)]"
  },
  later: {
    label: "LATER",
    accent: "from-violet-500 via-fuchsia-400 to-pink-300",
    panel: "bg-violet-50/75 border-violet-200/70",
    badge: "bg-violet-500 text-white",
    pill: "bg-white/70 text-violet-700",
    ring: "shadow-[0_20px_60px_-25px_rgba(139,92,246,0.7)]"
  }
} %>

<% total_count = @grouped.values.flatten.size %>
<% nearest_deadline = @grouped.values.flatten.min_by(&:deadline_at) %>

<div class="dashboard-page space-y-8 pb-8">
  <section class="dashboard-hero relative overflow-hidden rounded-[2rem] border border-white/50 bg-white/70 p-6 shadow-[0_30px_90px_-35px_rgba(15,23,42,0.55)] backdrop-blur-xl sm:p-8">
    <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-cyan-400 via-fuchsia-500 to-amber-300"></div>
    <div class="absolute inset-4 rounded-[1.5rem] border border-white/40"></div>
    <div class="absolute -right-8 top-6 h-28 w-28 rounded-full bg-fuchsia-300/40 blur-2xl"></div>
    <div class="absolute bottom-0 left-0 h-24 w-24 rounded-full bg-cyan-300/40 blur-2xl"></div>

    <div class="relative flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl dashboard-hero__copy">
        <h1 class="dashboard-hero__title mt-5 font-['Arial_Black','Trebuchet_MS',sans-serif] text-5xl font-black tracking-[-0.04em] text-slate-900 sm:text-6xl">Girigiri</h1>
      </div>

      <div class="dashboard-stats grid gap-3 sm:grid-cols-3">
        <div class="dashboard-stat dashboard-stat--dark border border-slate-900 bg-slate-950 px-5 py-4 text-white shadow-[6px_6px_0_0_rgba(15,23,42,0.9)]">
          <div class="text-xs uppercase tracking-[0.3em] text-cyan-300">Today</div>
          <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-2xl font-black"><%= Date.today.strftime("%m.%d") %></div>
          <div class="text-sm text-slate-300"><%= Date.today.strftime("%Y年%m月%d日") %></div>
        </div>
        <div class="dashboard-stat border border-slate-200 bg-white/85 px-5 py-4 shadow-[6px_6px_0_0_rgba(255,255,255,0.6)]">
          <div class="text-xs uppercase tracking-[0.3em] text-slate-400">Deadlines</div>
          <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-3xl font-black text-slate-900"><%= total_count %></div>
          <div class="text-sm text-slate-500">現在進行中</div>
        </div>
        <div class="dashboard-stat border border-slate-200 bg-white/85 px-5 py-4 shadow-[6px_6px_0_0_rgba(255,255,255,0.6)]">
          <div class="text-xs uppercase tracking-[0.3em] text-slate-400">Nearest</div>
          <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-lg font-black text-slate-900">
            <%= nearest_deadline ? nearest_deadline.deadline_at.strftime("%m/%d") : "--/--" %>
          </div>
          <div class="text-sm text-slate-500">
            <%= nearest_deadline ? nearest_deadline.event.title : "予定なし" %>
          </div>
        </div>
      </div>
    </div>

    <div class="dashboard-actions relative mt-6 flex flex-wrap gap-3">
      <%= link_to "ADD NEW", new_event_path, class: "dashboard-button dashboard-button--primary inline-flex items-center rounded-full border border-slate-900 bg-slate-950 px-5 py-3 text-sm font-black uppercase tracking-[0.18em] text-white transition hover:-translate-y-0.5 hover:bg-slate-800" %>
      <%= link_to "OPEN SIGNAGE", signage_path, class: "dashboard-button dashboard-button--secondary inline-flex items-center rounded-full border border-slate-200 bg-white/85 px-5 py-3 text-sm font-black uppercase tracking-[0.18em] text-slate-700 transition hover:-translate-y-0.5 hover:bg-white" %>
    </div>
  </section>

  <% [:today, :soon, :week, :later].each do |urgency| %>
    <% next if @grouped[urgency].blank? %>
    <% config = urgency_config[urgency] %>

    <section class="deadline-group deadline-group--<%= urgency %> space-y-4">
      <div class="deadline-group__header flex items-center gap-3 px-1">
        <div class="deadline-group__dot h-3 w-3 rounded-full bg-gradient-to-r <%= config[:accent] %>"></div>
        <h2 class="deadline-group__title text-sm font-black uppercase tracking-[0.35em] text-slate-700"><%= config[:label] %></h2>
        <div class="deadline-group__line h-px flex-1 bg-white/50"></div>
        <div class="deadline-group__count bg-white/70 px-3 py-1 text-xs font-semibold text-slate-500 backdrop-blur"><%= @grouped[urgency].size %>件</div>
      </div>

      <div class="dashboard-card-grid grid gap-5 lg:grid-cols-2">
        <% @grouped[urgency].each do |deadline| %>
          <% show_organizer = deadline.event.organizer.present? && !deadline.event.title.to_s.include?(deadline.event.organizer.to_s) %>
          <div class="deadline-card deadline-card--<%= urgency %> relative overflow-hidden border <%= config[:panel] %> p-5 backdrop-blur-xl transition duration-200 hover:-translate-y-1 <%= config[:ring] %>">
            <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r <%= config[:accent] %>"></div>
            <div class="absolute inset-3 rounded-[1.25rem] border border-white/40"></div>
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="deadline-card__category px-3 py-1 text-xs font-bold <%= config[:badge] %>">
                    <%= deadline.event.category %>
                  </span>
                  <% if show_organizer %>
                    <span class="deadline-card__organizer px-3 py-1 text-xs font-semibold <%= config[:pill] %>">
                      <%= deadline.event.organizer %>
                    </span>
                  <% end %>
                </div>
                <h3 class="mt-4 font-['Arial_Black','Trebuchet_MS',sans-serif] text-2xl font-black leading-tight tracking-[-0.03em] text-slate-900"><%= deadline.event.title %></h3>
                <div class="deadline-card__meta mt-3 flex flex-wrap gap-2 text-xs font-semibold text-slate-500">
                  <span class="deadline-card__meta-pill bg-white/80 px-3 py-1">締切 <%= deadline.deadline_at.strftime("%m/%d") %></span>
                  <% if deadline.event.source_url.present? %>
                    <%= link_to "リンクあり", deadline.event.source_url, class: "deadline-card__meta-pill bg-white/80 px-3 py-1 hover:bg-white", target: "_blank", rel: "noopener" %>
                  <% end %>
                  <%= link_to "編集", edit_event_path(deadline.event), class: "deadline-card__meta-pill bg-white/80 px-3 py-1 hover:bg-white" %>
                </div>
              </div>

              <div class="deadline-card__count shrink-0 border border-slate-900 bg-slate-950 px-5 py-4 text-center text-white shadow-[6px_6px_0_0_rgba(15,23,42,0.9)]">
                <% if deadline.days_remaining == 0 %>
                  <div class="text-xs font-black uppercase tracking-[0.3em] text-amber-300">Now</div>
                  <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-2xl font-black">今日</div>
                <% elsif deadline.days_remaining < 0 %>
                  <div class="text-xs font-black uppercase tracking-[0.3em] text-slate-400">Over</div>
                  <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-2xl font-black">終了</div>
                <% else %>
                  <div class="text-xs font-black uppercase tracking-[0.3em] text-cyan-300">Left</div>
                  <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-4xl font-black leading-none"><%= deadline.days_remaining %></div>
                  <div class="mt-1 text-xs font-semibold text-slate-300">days</div>
                <% end %>
              </div>
            </div>

            <% if deadline.event.entries.any? %>
              <% entry = deadline.event.entries.first %>
              <% status_config = {
                "todo" => { label: "未着手", bg: "bg-gray-100", text: "text-gray-600" },
                "drafting" => { label: "下書き中", bg: "bg-yellow-100", text: "text-yellow-700" },
                "submitted" => { label: "提出済み", bg: "bg-green-100", text: "text-green-700" },
                "skipped" => { label: "見送り", bg: "bg-red-100", text: "text-red-500" }
              } %>
              <% current = status_config[entry.status] %>
              <div class="deadline-card__status mt-3 flex gap-2 flex-wrap">
                <span class="text-xs text-gray-400">ステータス:</span>
                <span class="deadline-status-chip <%= current[:bg] %> <%= current[:text] %> text-xs px-2 py-1 font-medium">
                  <%= current[:label] %>
                </span>
                <div class="deadline-card__status-actions flex gap-1">
                  <% status_config.each do |status, config| %>
                    <% next if status == entry.status %>
                    <%= button_to config[:label],
                      update_status_entry_path(entry, status: status),
                      method: :patch,
                      class: "deadline-status-button text-xs px-2 py-1 border border-gray-200 text-gray-500 hover:border-gray-400 hover:text-gray-700" %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @grouped.empty? %>
    <section class="dashboard-empty rounded-[2rem] border border-dashed border-white/60 bg-white/55 px-6 py-20 text-center shadow-[0_30px_90px_-35px_rgba(15,23,42,0.45)] backdrop-blur-xl">
      <div class="text-xs font-black uppercase tracking-[0.45em] text-slate-400">No items yet</div>
      <h2 class="mt-4 font-['Arial_Black','Trebuchet_MS',sans-serif] text-3xl font-black uppercase tracking-[-0.03em] text-slate-900">まだ締切ゼロです</h2>
      <p class="mt-3 text-sm text-slate-600">最初の予定を入れると、この画面が一気ににぎやかになります。</p>
      <%= link_to "最初の締切を追加する", new_event_path, class: "mt-6 inline-flex rounded-full bg-slate-950 px-5 py-3 text-sm font-bold text-white transition hover:-translate-y-0.5 hover:bg-slate-800" %>
    </section>
  <% end %>
</div>
