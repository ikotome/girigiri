<div class="signage-page relative min-h-screen overflow-hidden px-6 py-10 sm:px-10 lg:px-16">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-0 top-0 h-72 w-72 rounded-full bg-cyan-400/25 blur-3xl"></div>
    <div class="absolute right-0 top-20 h-80 w-80 rounded-full bg-fuchsia-500/20 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/3 h-72 w-72 rounded-full bg-amber-300/10 blur-3xl"></div>
  </div>

  <div class="signage-page__inner relative mx-auto flex min-h-[calc(100vh-5rem)] max-w-6xl flex-col justify-between">
    <section class="signage-page__hero flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <div class="inline-flex -rotate-2 rounded-full border border-white/20 bg-cyan-300 px-4 py-1 text-[10px] font-black uppercase tracking-[0.4em] text-slate-950 shadow-[4px_4px_0_0_rgba(255,255,255,0.15)]">Girigiri Live Board</div>
        <div class="mt-5 font-['Arial_Black','Trebuchet_MS',sans-serif] text-6xl font-black uppercase tracking-[-0.05em] text-white sm:text-7xl lg:text-8xl">
          <%= @today.strftime("%m.%d") %>
        </div>
        <div class="mt-3 text-lg text-slate-300 sm:text-2xl"><%= @today.strftime("%Y年%m月%d日") %></div>
      </div>

      <div class="signage-page__summary rounded-[2rem] border border-white/10 bg-white/10 px-6 py-5 backdrop-blur-xl shadow-[8px_8px_0_0_rgba(255,255,255,0.08)]">
        <div class="text-xs font-black uppercase tracking-[0.35em] text-slate-300">This week</div>
        <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-5xl font-black text-white"><%= @deadlines.count %></div>
        <div class="text-sm text-slate-300">upcoming deadlines</div>
      </div>
    </section>

    <section class="signage-page__list mt-10 grid gap-4">
      <% @deadlines.each_with_index do |deadline, index| %>
        <% accent = {
          today: "from-rose-500 to-orange-300",
          soon: "from-orange-400 to-yellow-200",
          week: "from-cyan-400 to-sky-200",
          later: "from-violet-500 to-fuchsia-300"
        }[deadline.urgency] %>
        <div class="signage-card relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
          <div class="absolute inset-y-0 left-0 w-2 bg-gradient-to-b <%= accent %>"></div>
          <div class="absolute inset-4 rounded-[1.5rem] border border-white/10"></div>
          <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex items-start gap-5">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/10 font-['Arial_Black','Trebuchet_MS',sans-serif] text-xl font-black text-white">
                <%= index + 1 %>
              </div>
              <div>
                <div class="text-xs font-black uppercase tracking-[0.35em] text-slate-300"><%= deadline.event.category %></div>
                <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-3xl font-black uppercase tracking-[-0.03em] text-white sm:text-4xl"><%= deadline.event.title %></div>
                <% if deadline.event.organizer.present? %>
                  <div class="mt-2 text-base text-slate-300"><%= deadline.event.organizer %></div>
                <% end %>
              </div>
            </div>

            <div class="flex items-center gap-4 self-end lg:self-auto">
              <div class="rounded-full bg-white/10 px-4 py-2 text-sm font-bold text-slate-200">
                <%= deadline.deadline_at.strftime("%m/%d") %>
              </div>
              <div class="min-w-36 rounded-[1.5rem] border border-white/10 bg-slate-950/80 px-5 py-4 text-center shadow-[6px_6px_0_0_rgba(255,255,255,0.08)]">
                <% if deadline.days_remaining == 0 %>
                  <div class="text-xs font-black uppercase tracking-[0.3em] text-amber-300">Now</div>
                  <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-3xl font-black text-white">今日</div>
                <% else %>
                  <div class="text-xs font-black uppercase tracking-[0.3em] text-cyan-300">Left</div>
                  <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-4xl font-black text-white"><%= deadline.days_remaining %><span class="ml-1 text-lg text-slate-300">日</span></div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </section>
  </div>
</div>
