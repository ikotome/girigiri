<% week_days = (0..6).map { |offset| @today + offset.days } %>
<% weekday_labels = %w[日 月 火 水 木 金 土] %>
<% nearest_deadline = @deadlines.min_by(&:deadline_at) %>

<div class="signage-page signage-calendar-page relative min-h-screen overflow-hidden px-6 py-8 sm:px-8 lg:px-12">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-[-4rem] top-0 h-72 w-72 rounded-full bg-cyan-400/18 blur-3xl"></div>
    <div class="absolute right-[-3rem] top-20 h-80 w-80 rounded-full bg-fuchsia-500/16 blur-3xl"></div>
  </div>

  <div class="signage-page__inner relative mx-auto max-w-7xl space-y-6">
    <section class="signage-hero">
      <div class="signage-hero__glow signage-hero__glow--left"></div>
      <div class="signage-hero__glow signage-hero__glow--right"></div>
      <div class="signage-hero__inner">
        <div class="signage-hero__copy">
          <div class="signage-hero__sticker">Weekly runway</div>
          <h1 class="signage-hero__title">Girigiri Signage</h1>
          <div class="signage-hero__actions">
            <%= link_to "一覧に戻る", deadlines_path, class: "dashboard-button dashboard-button--secondary signage-hero__back" %>
          </div>
        </div>

        <div class="signage-hero__stats">
          <div class="dashboard-stat dashboard-stat--dark border border-slate-900 bg-slate-950 px-5 py-4 text-white shadow-[6px_6px_0_0_rgba(15,23,42,0.9)]">
            <div class="text-xs uppercase tracking-[0.3em] text-cyan-300">Today</div>
            <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-2xl font-black"><%= @today.strftime("%m.%d") %></div>
            <div class="text-sm text-slate-300"><%= @today.strftime("%Y年%m月%d日") %></div>
          </div>
          <div class="dashboard-stat border border-slate-200 bg-white/85 px-5 py-4 shadow-[6px_6px_0_0_rgba(255,255,255,0.6)]">
            <div class="text-xs uppercase tracking-[0.3em] text-slate-400">Deadlines</div>
            <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-3xl font-black text-slate-900"><%= @deadlines.count %></div>
            <div class="text-sm text-slate-500">7日以内</div>
          </div>
          <div class="dashboard-stat border border-slate-200 bg-white/85 px-5 py-4 shadow-[6px_6px_0_0_rgba(255,255,255,0.6)]">
            <div class="text-xs uppercase tracking-[0.3em] text-slate-400">Nearest</div>
            <div class="mt-2 font-['Arial_Black','Trebuchet_MS',sans-serif] text-lg font-black text-slate-900"><%= nearest_deadline ? nearest_deadline.deadline_at.strftime("%m/%d") : "--/--" %></div>
            <div class="text-sm text-slate-500"><%= nearest_deadline ? nearest_deadline.event.title : "予定なし" %></div>
          </div>
        </div>
      </div>
    </section>

    <section class="signage-calendar">
      <header class="signage-calendar__header">
        <% week_days.each do |day| %>
          <div class="signage-calendar__header-cell <%= "is-sunday" if day.sunday? %> <%= "is-saturday" if day.saturday? %>">
            <div class="signage-calendar__weekday"><%= weekday_labels[day.wday] %></div>
            <div class="signage-calendar__date"><%= day.strftime("%-m/%-d") %></div>
          </div>
        <% end %>
      </header>

      <div class="signage-calendar__body">
        <% if @deadlines.any? %>
          <% @deadlines.each_with_index do |deadline, index| %>
            <% end_day = [deadline.deadline_at.to_date, week_days.last].min %>
            <% start_col = 1 %>
            <% end_col = (end_day - @today).to_i + 2 %>
            <% accent = {
              today: "is-today",
              soon: "is-soon",
              week: "is-week",
              later: "is-later"
            }[deadline.urgency] %>

            <div class="signage-calendar__row">
              <div
                class="signage-calendar__event <%= accent %>"
                style="grid-column: <%= start_col %> / <%= end_col %>;"
              >
                <span class="signage-calendar__event-title"><%= deadline.event.title %></span>
              </div>

              <div class="signage-calendar__meta" style="grid-column: <%= [end_col, 7].min %> / 8;">
                <span><%= deadline.event.organizer.presence || deadline.event.category %></span>
                <% if deadline.days_remaining == 0 %>
                  <strong>今日</strong>
                <% else %>
                  <strong><%= deadline.days_remaining %>日</strong>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="signage-calendar__empty">
            今週の締切はまだありません
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
